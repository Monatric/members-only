<h1>Posts#index</h1>
<p>Find me in app/views/posts/index.html.erb</p>
<% if user_signed_in? %>
  <div>Name: <%= current_user.name %></div>
  <div>Email: <%= current_user.email %></div>
  <div><%= link_to "Create new post", new_post_path %></div>
  <br>
  <div><%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }  %><div>
<% else %>
  <%= link_to "Log in", new_user_session_path %><br />
  <%= link_to "Sign up", new_user_registration_path %><br />
<% end %>
<br>